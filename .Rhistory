NDCUtrack   <- NDC %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
Chl3QUtrack <- Chl3Q %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
# Give each row a unique key per set
NDCUtrack   <- NDCUtrack   %>% mutate(key = paste0("NDC_",  row_number(), "_", PeakCoord))
Chl3QUtrack <- Chl3QUtrack %>% mutate(key = paste0("CHL_", row_number(), "_", PeakCoord))
# Find shared PeakCoords and create shared keys for them
shared_coords <- intersect(
sub("NDC_\\d+_", "", NDCUtrack$key),
sub("CHL_\\d+_", "", Chl3QUtrack$key)
)
shared_keys <- paste0("SHARED_", seq_along(shared_coords), "_", shared_coords)
tss_list <- list(
NDCUtrack   = c(NDCUtrack$key,   shared_keys),
Chl3QUtrack = c(Chl3QUtrack$key, shared_keys)
)
upset(
fromList(tss_list),
sets = c("NDCUtrack", "Chl3QUtrack"),
order.by = "freq",
keep.order = TRUE,
sets.bar.color = c("grey", "#108080"),
main.bar.color = "grey30",
text.scale = 1.4,
point.size = 3,
line.size = 1,
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.6, 0.4)
)
