sets = c("NDCUtrack", "Ksg3QUtrack"),
order.by = "freq",
keep.order = TRUE,
sets.bar.color = c("grey", "#800040"),
main.bar.color = "grey30",
text.scale = 1.4,
point.size = 3,
line.size = 1,
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.6, 0.4)
)
View(Ksg3QUtrack)
View(NDCUtrack)
