df <- read.csv("~/Desktop/Stuff/AMeyer_Lab/Experiment_results/3seq/RNAFOLD/RNAfold_DRIVE/Spn/Chl/Nofilter/outputresults.csv")
NDC         <- df %>% filter(Sig_Control == 1)
Chl3Q       <- df %>% filter(Sig_Cond2 == 1)
NDCUtrack   <- NDC %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
Chl3QUtrack <- Chl3Q %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
# Give every row a unique key
NDCUtrack   <- NDCUtrack   %>% mutate(key = paste0(PeakCoord, "_NDC_", row_number()))
Chl3QUtrack <- Chl3QUtrack %>% mutate(key = paste0(PeakCoord, "_CHL_", row_number()))
# Find shared PeakCoords
shared_coords <- intersect(NDCUtrack$PeakCoord, Chl3QUtrack$PeakCoord)
# For rows whose PeakCoord is shared, replace their key with just PeakCoord
# so they match across sets
NDCUtrack <- NDCUtrack %>%
mutate(key = ifelse(PeakCoord %in% shared_coords, PeakCoord, key))
Chl3QUtrack <- Chl3QUtrack %>%
mutate(key = ifelse(PeakCoord %in% shared_coords, PeakCoord, key))
cat("NDCUtrack total rows:", nrow(NDCUtrack), "\n")
cat("Chl3QUtrack total rows:", nrow(Chl3QUtrack), "\n")
cat("Shared PeakCoords:", length(shared_coords), "\n")
tss_list <- list(
NDCUtrack   = NDCUtrack$key,
Chl3QUtrack = Chl3QUtrack$key
)
upset(
fromList(tss_list),
sets = c("NDCUtrack", "Chl3QUtrack"),
order.by = "freq",
keep.order = TRUE,
sets.bar.color = c("grey", "#108080"),
main.bar.color = "grey30",
text.scale = 1.4,
point.size = 3,
line.size = 1,
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.6, 0.4)
)
rm(list=ls())
lapply(c("dplyr", "UpSetR"), library, character.only=T)
df <- read.csv("~/Desktop/Stuff/AMeyer_Lab/Experiment_results/3seq/RNAFOLD/RNAfold_DRIVE/Spn/Chl/Nofilter/outputresults.csv")
NDC         <- df %>% filter(Sig_Control == 1)
Chl3Q       <- df %>% filter(Sig_Cond2 == 1)
NDCUtrack   <- NDC %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
Chl3QUtrack <- Chl3Q %>% filter(FreefoldingEnergy <= -10 & Utrack == "yes")
# Give every row a unique key first
NDCUtrack   <- NDCUtrack   %>% mutate(key = paste0(PeakCoord, "_NDC_", row_number()))
Chl3QUtrack <- Chl3QUtrack %>% mutate(key = paste0(PeakCoord, "_CHL_", row_number()))
# Find shared PeakCoords
shared_coords <- intersect(NDCUtrack$PeakCoord, Chl3QUtrack$PeakCoord)
# For shared PeakCoords, assign matching keys per occurrence
# e.g. first occurrence of "chr1:100-200" in NDC matches first in Chl, second matches second, etc.
for (coord in shared_coords) {
ndc_idx <- which(NDCUtrack$PeakCoord == coord)
chl_idx <- which(Chl3QUtrack$PeakCoord == coord)
# Pair them up occurrence by occurrence
n_pairs <- min(length(ndc_idx), length(chl_idx))
for (j in seq_len(n_pairs)) {
shared_key <- paste0(coord, "_SHARED_", j)
NDCUtrack$key[ndc_idx[j]]   <- shared_key
Chl3QUtrack$key[chl_idx[j]] <- shared_key
}
# Any extra occurrences beyond the pairs keep their unique keys
}
cat("NDCUtrack total keys:", length(NDCUtrack$key), "\n")
cat("Chl3QUtrack total keys:", length(Chl3QUtrack$key), "\n")
cat("Shared pairs:", length(intersect(NDCUtrack$key, Chl3QUtrack$key)), "\n")
tss_list <- list(
NDCUtrack   = NDCUtrack$key,
Chl3QUtrack = Chl3QUtrack$key
)
upset(
fromList(tss_list),
sets = c("NDCUtrack", "Chl3QUtrack"),
order.by = "freq",
keep.order = TRUE,
sets.bar.color = c("grey", "#108080"),
main.bar.color = "grey30",
text.scale = 1.4,
point.size = 3,
line.size = 1,
mainbar.y.label = "Intersection Size",
sets.x.label = "Set Size",
mb.ratio = c(0.6, 0.4)
)
